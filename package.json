{
    "name": "abascbasic",
    "displayName": "Abasc Compiler",
    "description": "Support for Locomotive Basic Syntax.",
    "version": "1.1.1",
    "publisher": "fragarco",
    "engines": {
        "vscode": "^1.12.0"
    },
    "icon": "images/Locomotive_BASIC_amstrad_cpc.PNG",
    "categories": [
        "Programming Languages"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/fragarco/abasc-vscode.git"
    },
    "main": "./out/extension.js",
    "activationEvents": [
        "onLanguage:abascbasic"
    ],
    "contributes": {
        "languages": [
            {
                "id": "abascbasic",
                "aliases": [
                    "Locomotive Basic",
                    "Amstrad Basic",
                    "CPC Basic"
                ],
                "extensions": [
                    ".bas"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "abascbasic",
                "scopeName": "source.abascbasic",
                "path": "./syntaxes/amstradbasic.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "build": "npx tsc && vsce package -o out"
    },
    "dependencies": {
        "@types/vscode": "^1.110.0",
        "typescript": "^5.9.3"
    }
}
